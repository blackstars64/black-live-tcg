# BlackLiveTCG — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# .env est gitignored (usage perso, non distribué sur stores)

# ─── Cardmarket API (OAuth 1.0a — Dedicated App) ─────────────────
# Créer une app sur : https://www.cardmarket.com/fr/Magic/Account/API
# → "Add App" → récupérer les 4 tokens

EXPO_PUBLIC_CM_APP_TOKEN=
EXPO_PUBLIC_CM_APP_SECRET=
EXPO_PUBLIC_CM_ACCESS_TOKEN=
EXPO_PUBLIC_CM_ACCESS_SECRET=

# ─── Pokémon TCG API (optionnel — rate limit x10 avec clé) ───────
# Clé gratuite sur : https://dev.pokemontcg.io/
EXPO_PUBLIC_POKEMON_API_KEY=
