# BlackLiveTCG — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs

# ─── Pokémon TCG API (optionnel — rate limit x10 avec clé) ───────
# Clé gratuite sur : https://dev.pokemontcg.io/
EXPO_PUBLIC_POKEMON_API_KEY=

# ─── Gemini Flash (identification IA — 3e étape du pipeline) ──────
# Clé gratuite sur : https://aistudio.google.com/app/apikey
# Quota gratuit : 15 req/min, 1500 req/j (Gemini 2.0 Flash)
EXPO_PUBLIC_GEMINI_API_KEY=

# ─── pHash DB (identification locale — 1re étape du pipeline) ────
# URL du fichier phash.db uploadé sur GitHub Releases
# Format : https://github.com/blackstars64/black-live-tcg/releases/download/vX.X/phash.db
EXPO_PUBLIC_PHASH_DB_URL=
